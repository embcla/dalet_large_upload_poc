# Local-development defaults for the docker-compose stack.
# Not for production use.

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=media-uploads

# Least-privilege credentials the backend uses to talk to MinIO (created by
# the minio-init service, scoped to MINIO_BUCKET via minio/policy.json).
MINIO_SERVICE_ACCESS_KEY=media-uploader
MINIO_SERVICE_SECRET_KEY=media-uploader-secret

CORS_ORIGIN=http://localhost:4200

# Throttles backend -> MinIO upload traffic via toxiproxy (KB/s), so upload
# progress is visible in the UI on a fast local network. Raise this (e.g. to
# 1000000) to effectively disable throttling.
UPLOAD_THROTTLE_RATE_KB=20000
