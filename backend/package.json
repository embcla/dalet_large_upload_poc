{
  "name": "media-upload-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Backend for the media upload platform: Express + tus + S3 (MinIO) + SQLite",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
